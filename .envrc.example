# Copy to .envrc and fill in. Only the values that must vary per deploy or that
# are secret are injected; everything else is pinned in compose.yml.

export QUANTUM_ENDPOINT="..."
export QUANTUM_STACK="mattermost-${QUANTUM_ENDPOINT}"

# Public hostname. quantum-caddy issues a cert for this and routes to it.
export DOMAIN=mattermost.${QUANTUM_ENDPOINT}.customer.planetary-quantum.net

# Postgres password (also used in the Mattermost DSN).
export POSTGRES_PASSWORD=change-me-to-a-strong-secret

# Mattermost (Team edition) image tag.
export MATTERMOST_IMAGE_TAG=11.8.1

# File storage: Quantum S3-compatible object storage.
# Get your credentials: https://ostor-usage.pqapp.dev/
# create the bucket before
export S3_BUCKET=change-me
export S3_REGION=us-east-1
export S3_ENDPOINT=s3.planetary-networks.de
export S3_ACCESS_KEY=change-me
export S3_SECRET_KEY=change-me
